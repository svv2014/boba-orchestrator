# Optional: absolute path to a TTS script that produces an audio file from text.
# When unset, voice notifications are disabled (text-only fallback).
# BOBA_TTS_SCRIPT=/absolute/path/to/your/tts_script.sh

# Optional: absolute path to a shell script invoked on worker escalation.
# When unset, escalation only logs.
# BOBA_NOTIFY_SCRIPT=/path/to/signal-notify.sh

# Signal sender phone number — required if BOBA_NOTIFY_SCRIPT uses Signal.
SIGNAL_ACCOUNT=+1xxxxxxxxxx

# Directory where per-run JSONL transcript files are written.
# Each orchestrator run creates <run_id>.jsonl here.
# Files older than 7 days are deleted automatically on startup.
# ORCHESTRATOR_TRANSCRIPT_DIR=/tmp/orchestrator-transcripts

# Path to the Claude CLI binary.
# Optional — if unset, the orchestrator will find `claude` on your PATH via shutil.which.
# Example: /home/user/.local/bin/claude
# CLAUDE_CLI_PATH=

# Deprecated alias for CLAUDE_CLI_PATH. Use CLAUDE_CLI_PATH instead.
# CLAUDE_BIN=

# Optional: absolute path to a script that ingests a finished session into an
# external memory store / event bus. When unset, session-end flush is a no-op.
# The script is invoked as: <script> memory.session_ended <json_payload> 0 6
# BOBA_SESSION_FLUSH_SCRIPT=/path/to/session-flush.sh
